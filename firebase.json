{
  "hosting": [
    {
      "site": "cedarrapidsstemcircle",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/",
          "destination": "https://crstemcircle.org/",
          "type": 301
        },
        {
          "source": "/:splat",
          "destination": "https://crstemcircle.org/:splat",
          "type": 301
        },
        {
          "source": "/**/*",
          "destination": "https://crstemcircle.org/:splat",
          "type": 301
        }
      ]
    },
    {
      "site": "crstemcircle",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/signup",
          "destination": "https://docs.google.com/forms/d/e/1FAIpQLSe4TsXYQ1tOl8KoPx970e1iAHAOwQvULpSXKfMJLrijkkXvVw/viewform?usp=dialog",
          "type": 302
        }
      ]
    }
  ]
}
